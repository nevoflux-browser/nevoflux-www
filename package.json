{
  "name": "nevoflux-www",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "astro dev --port 3000",
    "build": "node scripts/fetch-release-notes.mjs && astro build",
    "fetch:releases": "node scripts/fetch-release-notes.mjs",
    "preview": "astro build && wrangler dev --port 3000",
    "typecheck": "astro check",
    "lint": "eslint . --max-warnings=0 --cache",
    "lint:fix": "eslint . --fix",
    "spell": "cspell \"**/*.{ts,tsx,js,jsx,astro,md,json,yml,yaml}\"",
    "format": "prettier . --check --cache",
    "format:fix": "prettier . --write --cache",
    "test": "vitest run",
    "test:coverage": "vitest --coverage",
    "test:playwright": "playwright test --reporter=list",
    "commitlint": "commitlint --edit",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.4",
    "@astrojs/cloudflare": "^12.6.13",
    "@astrojs/react": "^4.2.0",
    "@astrojs/sitemap": "^3.2.1",
    "@astrojs/tailwind": "^6.0.2",
    "@fontsource/bricolage-grotesque": "^5.1.1",
    "astro": "^5.7.0",
    "better-auth": "^1.6.20",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "smol-toml": "^1.7.0",
    "tailwind-merge": "^3.0.2",
    "typescript": "^5.9.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "@playwright/test": "^1.52.0",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@typescript-eslint/eslint-plugin": "^8.30.0",
    "@typescript-eslint/parser": "^8.30.0",
    "@vitest/coverage-istanbul": "^3.1.0",
    "autoprefixer": "^10.4.20",
    "better-sqlite3": "^12.11.1",
    "cspell": "^8.17.0",
    "eslint": "^9.24.0",
    "eslint-config-prettier": "^10.1.0",
    "eslint-plugin-astro": "^1.3.1",
    "eslint-plugin-jsx-a11y": "^6.10.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "jsdom": "^26.1.0",
    "lefthook": "^1.11.0",
    "marked": "^18.0.5",
    "postcss": "^8.5.3",
    "prettier": "^3.5.3",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "sharp": "^0.34.1",
    "tailwindcss": "^3.4.17",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.1.0",
    "wrangler": "^4.104.0"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.8.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "sharp",
      "workerd"
    ]
  }
}
