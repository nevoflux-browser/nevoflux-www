---
import { getLocale, getUI, getPath } from '~/utils/i18n';
import { GITHUB_URL, DISCORD_URL, X_URL } from '~/constants';
import Logo from './Logo.astro';

const locale = getLocale(Astro.url);
const ui = getUI(locale);
---

<footer class="border-dark/10 bg-surface/30 border-t py-12">
  <div class="container">
    <div class="flex flex-col items-center gap-6 md:flex-row md:justify-between">
      <!-- Brand -->
      <div class="flex items-center gap-2.5">
        <Logo size={24} />
        <span class="font-semibold tracking-tight">
          <span class="text-accent">Nevo</span>Flux
        </span>
      </div>

      <!-- Links -->
      <div class="flex items-center gap-6 text-sm text-muted">
        <span>{ui.footer.builtWith}</span>
        <a
          href={GITHUB_URL}
          class="transition-colors hover:text-accent"
          target="_blank"
          rel="noopener noreferrer"
        >
          {ui.footer.license}
        </a>
        <a
          href={X_URL}
          class="transition-colors hover:text-accent"
          target="_blank"
          rel="noopener noreferrer"
        >
          X
        </a>
        <a
          href={DISCORD_URL}
          class="transition-colors hover:text-accent"
          target="_blank"
          rel="noopener noreferrer"
        >
          Discord
        </a>
        <a href={getPath(locale, '/privacy-policy')} class="transition-colors hover:text-accent">
          {ui.footer.privacy}
        </a>
      </div>
    </div>

    <div class="border-dark/5 mt-8 border-t pt-6 text-center text-sm text-muted">
      <p>{ui.footer.copyright}</p>
    </div>
  </div>
</footer>
