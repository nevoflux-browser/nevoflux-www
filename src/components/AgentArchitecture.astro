---
import { getLocale, getUI } from '~/utils/i18n';

const locale = getLocale(Astro.url);
const ui = getUI(locale);

const layers = [
  {
    ...ui.agentArch.llm,
    icon: `<circle cx="12" cy="12" r="3"/><path d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M1 12h4M19 12h4M4.22 19.78l2.83-2.83M16.95 7.05l2.83-2.83"/>`,
    color: 'from-blue-500/20 to-blue-600/5',
    border: 'border-blue-500/20',
    iconBg: 'bg-blue-500/10 text-blue-600',
  },
  {
    ...ui.agentArch.coding,
    icon: `<polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>`,
    color: 'from-accent/20 to-accent/5',
    border: 'border-accent/20',
    iconBg: 'bg-accent/10 text-accent',
  },
  {
    ...ui.agentArch.operator,
    icon: `<polyline points="17 1 21 5 17 9"/><path d="M3 11V9a4 4 0 0 1 4-4h14"/><polyline points="7 23 3 19 7 15"/><path d="M21 13v2a4 4 0 0 1-4 4H3"/>`,
    color: 'from-purple-500/20 to-purple-600/5',
    border: 'border-purple-500/20',
    iconBg: 'bg-purple-500/10 text-purple-600',
  },
];
---

<section class="bg-surface/30 py-24 lg:py-32">
  <div class="container">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-3xl font-bold tracking-tight md:text-5xl">{ui.agentArch.title}</h2>
      <p class="mt-4 text-lg text-subtle">{ui.agentArch.subtitle}</p>
    </div>

    <div class="mt-16 grid gap-8 md:grid-cols-3">
      {
        layers.map((layer) => (
          <div
            class={`relative overflow-hidden rounded-2xl border ${layer.border} bg-gradient-to-b ${layer.color} p-8 transition-all hover:scale-[1.02]`}
          >
            <div
              class={`mb-4 inline-flex h-12 w-12 items-center justify-center rounded-xl ${layer.iconBg}`}
            >
              <svg
                class="h-6 w-6"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <Fragment set:html={layer.icon} />
              </svg>
            </div>

            <div class="mb-2 text-xs font-semibold uppercase tracking-wider text-subtle">
              {layer.role}
            </div>
            <h3 class="text-2xl font-bold">{layer.label}</h3>
            <p class="mt-3 leading-relaxed text-subtle">{layer.description}</p>
          </div>
        ))
      }
    </div>

    <!-- Formula -->
    <div class="mt-12 text-center">
      <div
        class="border-accent/20 bg-accent/5 inline-flex items-center gap-3 rounded-2xl border px-8 py-4 text-lg font-semibold tracking-tight md:text-xl"
      >
        <span class="text-accent">{ui.agentArch.formula}</span>
      </div>
    </div>
  </div>
</section>
