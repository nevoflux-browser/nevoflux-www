---
export const prerender = false;

import Layout from '~/layouts/Layout.astro';
import NavBar from '~/components/NavBar.astro';
import Footer from '~/components/Footer.astro';
import { getLocale, getUI, getPath } from '~/utils/i18n';
import { getRuntimeEnv } from '~/lib/runtime';
import { searchPacks, parsePackRow } from '~/lib/packs/db';

const locale = getLocale(Astro.url);
const ui = getUI(locale);
const q = Astro.url.searchParams.get('q') ?? '';
const packs = (await searchPacks(getRuntimeEnv(Astro.locals).DB, q)).map(parsePackRow);
const href = (id: string) => getPath(locale, `/packs/${id}`);
---

<Layout title={`${ui.registry.title} · ${ui.site.title}`} description={ui.registry.subtitle}>
  <NavBar />
  <main class="container min-h-screen py-32">
    <div class="mx-auto max-w-5xl">
      <header class="text-center">
        <h1 class="text-4xl font-bold tracking-tight text-dark md:text-5xl">
          {ui.registry.title}
        </h1>
        <p class="mt-3 text-lg text-subtle">{ui.registry.subtitle}</p>
      </header>

      <div class="mt-10 flex flex-col gap-3 sm:flex-row sm:items-center">
        <form method="get" class="flex flex-1 gap-2">
          <input
            type="search"
            name="q"
            value={q}
            placeholder={ui.registry.searchPlaceholder}
            class="border-dark/15 w-full rounded-lg border px-4 py-2.5 text-sm outline-none focus:border-accent"
          />
          <button
            type="submit"
            class="border-dark/15 hover:border-accent/40 rounded-lg border px-4 py-2.5 text-sm font-medium transition-colors"
            >{ui.registry.searchBtn}</button
          >
        </form>
        <div class="flex items-center gap-2">
          <div class="border-dark/10 inline-flex overflow-hidden rounded-lg border">
            <button
              id="view-card"
              class="inline-flex items-center justify-center p-2 transition-colors"
              aria-label={ui.registry.viewCard}
              title={ui.registry.viewCard}
            >
              <svg
                class="h-4 w-4"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <rect x="3" y="3" width="7" height="7" rx="1"></rect>
                <rect x="14" y="3" width="7" height="7" rx="1"></rect>
                <rect x="14" y="14" width="7" height="7" rx="1"></rect>
                <rect x="3" y="14" width="7" height="7" rx="1"></rect>
              </svg>
            </button>
            <button
              id="view-list"
              class="border-dark/10 inline-flex items-center justify-center border-l p-2 transition-colors"
              aria-label={ui.registry.viewList}
              title={ui.registry.viewList}
            >
              <svg
                class="h-4 w-4"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <line x1="8" y1="6" x2="21" y2="6"></line>
                <line x1="8" y1="12" x2="21" y2="12"></line>
                <line x1="8" y1="18" x2="21" y2="18"></line>
                <line x1="3" y1="6" x2="3.01" y2="6"></line>
                <line x1="3" y1="12" x2="3.01" y2="12"></line>
                <line x1="3" y1="18" x2="3.01" y2="18"></line>
              </svg>
            </button>
          </div>
          <a
            href={getPath(locale, '/packs/publish')}
            class="rounded-lg bg-accent px-4 py-2.5 text-sm font-medium text-white transition-colors hover:bg-accent-hover"
            >{ui.registry.publish}</a
          >
        </div>
      </div>

      {
        packs.length === 0 ? (
          <p class="mt-16 text-center text-muted">{ui.registry.empty}</p>
        ) : (
          <div id="results" class="mt-8" data-view="card">
            <div id="cards" class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
              {packs.map((p) => (
                <a
                  href={href(p.id)}
                  class="border-dark/10 bg-surface/30 hover:border-accent/30 block rounded-2xl border p-5 transition-colors"
                >
                  <div class="flex items-center gap-2">
                    <h3 class="font-bold text-dark">{p.metadata.displayName || p.name}</h3>
                    {p.is_official === 1 && (
                      <span class="bg-accent/10 rounded-full px-2 py-0.5 text-xs font-medium text-accent">
                        {ui.registry.official}
                      </span>
                    )}
                  </div>
                  <p class="mt-2 line-clamp-2 text-sm text-subtle">{p.description}</p>
                  <div class="mt-3 text-xs text-muted">
                    v{p.version} · ★ {p.star_count ?? 0} · ⤓ {p.download_count}
                  </div>
                </a>
              ))}
            </div>
            <div id="list" class="divide-dark/5 border-dark/10 hidden divide-y rounded-2xl border">
              {packs.map((p) => (
                <a href={href(p.id)} class="hover:bg-surface/40 flex items-center gap-3 p-4">
                  <span class="font-medium text-dark">{p.metadata.displayName || p.name}</span>
                  {p.is_official === 1 && (
                    <span class="bg-accent/10 rounded-full px-2 py-0.5 text-xs font-medium text-accent">
                      {ui.registry.official}
                    </span>
                  )}
                  <span class="line-clamp-1 flex-1 text-sm text-subtle">{p.description}</span>
                  <span class="shrink-0 text-xs text-muted">
                    v{p.version} · ★ {p.star_count ?? 0} · ⤓ {p.download_count}
                  </span>
                </a>
              ))}
            </div>
          </div>
        )
      }
    </div>
  </main>
  <Footer />
</Layout>

<script>
  const results = document.getElementById('results');
  const cards = document.getElementById('cards');
  const list = document.getElementById('list');
  const btnCard = document.getElementById('view-card');
  const btnList = document.getElementById('view-list');

  function apply(view: string) {
    if (!results || !cards || !list) return;
    results.dataset.view = view;
    const card = view !== 'list';
    cards.classList.toggle('hidden', !card);
    list.classList.toggle('hidden', card);
    btnCard?.classList.toggle('text-accent', card);
    btnList?.classList.toggle('text-accent', !card);
  }

  apply(localStorage.getItem('packs-view') || 'card');
  btnCard?.addEventListener('click', () => {
    localStorage.setItem('packs-view', 'card');
    apply('card');
  });
  btnList?.addEventListener('click', () => {
    localStorage.setItem('packs-view', 'list');
    apply('list');
  });
</script>
