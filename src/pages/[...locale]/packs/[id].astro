---
export const prerender = false;

import Layout from '~/layouts/Layout.astro';
import NavBar from '~/components/NavBar.astro';
import Footer from '~/components/Footer.astro';
import { getLocale, getUI, getPath } from '~/utils/i18n';
import { getRuntimeEnv } from '~/lib/runtime';
import { getSessionUser } from '~/lib/session';
import { getPackById, parsePackRow, getPublisher, isAdmin, hasStarred } from '~/lib/packs/db';

const locale = getLocale(Astro.url);
const ui = getUI(locale);
const id = Astro.params.id ?? '';
const env = getRuntimeEnv(Astro.locals);

const row = await getPackById(env.DB, id);
const pack = row ? parsePackRow(row) : null;
const publisher = row ? await getPublisher(env.DB, row.publisher_user_id) : null;
if (!pack) Astro.response.status = 404;

const publisherName = publisher?.name || publisher?.email || (pack ? pack.github_owner : '');
const installHref = pack ? `nevoflux://pack-install?src=${pack.install_src}` : '#';

// The publisher, or any allowlisted admin, may delete a pack.
const currentUser = pack ? await getSessionUser(Astro.locals, Astro.request) : null;
const isOwner = !!(pack && currentUser && currentUser.id === pack.publisher_user_id);
const canDelete = isOwner || (!!currentUser && (await isAdmin(env.DB, currentUser.email)));

const meta = pack
  ? [
      { label: ui.detail.version, value: pack.version },
      { label: ui.detail.license, value: pack.license || ui.detail.none },
      { label: ui.detail.downloads, value: String(pack.download_count) },
      { label: ui.detail.publisher, value: publisherName },
    ]
  : [];

const displayName = pack ? pack.metadata.displayName || pack.name : '';
const categories = pack?.metadata.categories ?? [];
const topics = pack?.metadata.topics ?? [];
const releaseTags = pack?.metadata.releaseTags ?? [];
const hasChips = categories.length + topics.length + releaseTags.length > 0;

const starCount = pack ? (pack.star_count ?? 0) : 0;
const starred = pack && currentUser ? await hasStarred(env.DB, id, currentUser.id) : false;
---

<Layout
  title={`${pack ? pack.name : ui.detail.notFound} · ${ui.site.title}`}
  description={pack?.description ?? ui.detail.notFound}
>
  <NavBar />
  <main class="container min-h-screen py-32">
    {
      !pack ? (
        <p class="mt-16 text-center text-muted">{ui.detail.notFound}</p>
      ) : (
        <article class="mx-auto max-w-3xl">
          <header class="flex flex-wrap items-center gap-3">
            <h1 class="text-3xl font-bold tracking-tight text-dark md:text-4xl">{displayName}</h1>
            {pack.is_official === 1 && (
              <span class="bg-accent/10 rounded-full px-2.5 py-1 text-xs font-medium text-accent">
                {ui.detail.official}
              </span>
            )}
          </header>

          {pack.description && <p class="mt-3 text-lg text-subtle">{pack.description}</p>}

          {hasChips && (
            <div class="mt-4 flex flex-wrap gap-2">
              {categories.map((c) => (
                <span class="border-dark/15 rounded-full border px-2.5 py-0.5 text-xs text-subtle">
                  {c}
                </span>
              ))}
              {topics.map((tp) => (
                <span class="rounded-full bg-surface px-2.5 py-0.5 text-xs text-subtle">#{tp}</span>
              ))}
              {releaseTags.map((rt) => (
                <span class="bg-accent/10 rounded-full px-2.5 py-0.5 text-xs font-medium text-accent">
                  {rt}
                </span>
              ))}
            </div>
          )}

          <div class="mt-6 flex flex-wrap items-center gap-4">
            <a
              id="install-btn"
              href={installHref}
              data-pack-id={pack.id}
              class="rounded-lg bg-accent px-6 py-3 text-sm font-medium text-white transition-colors hover:bg-accent-hover"
            >
              {ui.detail.install}
            </a>
            <button
              id="star-btn"
              data-pack-id={pack.id}
              data-starred={starred ? '1' : '0'}
              data-logged-in={currentUser ? '1' : '0'}
              data-login-url={getPath(locale, '/login')}
              aria-label={ui.detail.stars}
              class:list={[
                'inline-flex items-center gap-1.5 rounded-lg border px-4 py-3 text-sm font-medium transition-colors',
                starred
                  ? 'border-accent/40 text-accent'
                  : 'border-dark/15 text-subtle hover:text-accent',
              ]}
            >
              <span id="star-icon">{starred ? '★' : '☆'}</span>
              <span id="star-count">{starCount}</span>
            </button>
            <a
              href={pack.github_url}
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm font-medium text-subtle transition-colors hover:text-accent"
            >
              {ui.detail.source} ↗
            </a>
            {canDelete && (
              <button
                id="delete-btn"
                data-pack-id={pack.id}
                data-confirm={ui.detail.deleteConfirm}
                data-packs-url={getPath(locale, '/packs')}
                class="ml-auto text-sm font-medium text-red-600 transition-colors hover:text-red-700"
              >
                {ui.detail.delete}
              </button>
            )}
          </div>

          <dl class="border-dark/10 bg-surface/30 mt-8 grid grid-cols-2 gap-x-6 gap-y-3 rounded-2xl border p-6 text-sm sm:grid-cols-3">
            {meta.map((m) => (
              <div>
                <dt class="text-xs text-muted">{m.label}</dt>
                <dd class="mt-0.5 font-medium text-dark">{m.value}</dd>
              </div>
            ))}
          </dl>

          <section class="mt-8">
            <h2 class="text-sm font-semibold uppercase tracking-wide text-subtle">
              {ui.detail.readme}
            </h2>
            {pack.metadata.readme ? (
              <div class="prose mt-2 max-w-none" data-md={pack.metadata.readme} />
            ) : (
              <p class="mt-2 text-sm text-muted">{ui.detail.none}</p>
            )}
          </section>

          <section class="mt-8">
            <h2 class="text-sm font-semibold uppercase tracking-wide text-subtle">
              {ui.detail.skills}
            </h2>
            {pack.metadata.skillsText ? (
              <div class="prose mt-2 max-w-none" data-md={pack.metadata.skillsText} />
            ) : (
              <p class="mt-2 text-sm text-muted">{ui.detail.none}</p>
            )}
          </section>

          <section class="mt-8">
            <h2 class="text-sm font-semibold uppercase tracking-wide text-subtle">
              {ui.detail.seed}
            </h2>
            {pack.metadata.seedText ? (
              <div class="prose mt-2 max-w-none" data-md={pack.metadata.seedText} />
            ) : (
              <p class="mt-2 text-sm text-muted">{ui.detail.none}</p>
            )}
          </section>

          <section class="mt-8">
            <h2 class="text-sm font-semibold uppercase tracking-wide text-subtle">
              {ui.detail.dashboard}
            </h2>
            {pack.metadata.dashboardText ? (
              <div class="prose mt-2 max-w-none" data-md={pack.metadata.dashboardText} />
            ) : (
              <p class="mt-2 text-sm text-muted">{ui.detail.none}</p>
            )}
          </section>
        </article>
      )
    }
  </main>
  <Footer />
</Layout>

<script>
  import { marked } from 'marked';
  import DOMPurify from 'dompurify';

  // Render publisher-supplied markdown safely (sanitized — content is untrusted).
  document.querySelectorAll<HTMLElement>('[data-md]').forEach((el) => {
    const md = el.dataset.md ?? '';
    el.innerHTML = DOMPurify.sanitize(marked.parse(md, { async: false }) as string);
  });

  const btn = document.getElementById('install-btn');
  btn?.addEventListener('click', () => {
    const id = btn.dataset.packId;
    if (id) navigator.sendBeacon(`/api/packs/${id}/install`);
  });

  const star = document.getElementById('star-btn');
  star?.addEventListener('click', async () => {
    if (star.dataset.loggedIn !== '1') {
      window.location.href = star.dataset.loginUrl || '/login';
      return;
    }
    const res = await fetch(`/api/packs/${star.dataset.packId}/star`, { method: 'POST' });
    if (!res.ok) return;
    const data = (await res.json()) as { starred: boolean; starCount: number };
    star.dataset.starred = data.starred ? '1' : '0';
    const icon = document.getElementById('star-icon');
    const count = document.getElementById('star-count');
    if (icon) icon.textContent = data.starred ? '★' : '☆';
    if (count) count.textContent = String(data.starCount);
    star.classList.toggle('text-accent', data.starred);
    star.classList.toggle('border-accent/40', data.starred);
    star.classList.toggle('text-subtle', !data.starred);
    star.classList.toggle('border-dark/15', !data.starred);
  });

  const del = document.getElementById('delete-btn');
  del?.addEventListener('click', async () => {
    const id = del.dataset.packId;
    if (!id || !window.confirm(del.dataset.confirm || 'Delete this pack?')) return;
    const res = await fetch(`/api/packs/${id}/delete`, { method: 'POST' });
    if (res.ok) {
      window.location.href = del.dataset.packsUrl || '/packs';
    } else {
      const data = (await res.json().catch(() => ({}))) as { error?: string };
      window.alert(data.error || `Delete failed (${res.status})`);
    }
  });
</script>
