---
export const prerender = false;

import Layout from '~/layouts/Layout.astro';
import NavBar from '~/components/NavBar.astro';
import Footer from '~/components/Footer.astro';
import { getLocale, getUI, getPath } from '~/utils/i18n';
import { getRuntimeEnv } from '~/lib/runtime';
import { getSessionUser } from '~/lib/session';
import { getPackById, parsePackRow, getPublisher, isAdmin, hasStarred } from '~/lib/packs/db';

const locale = getLocale(Astro.url);
const ui = getUI(locale);
const id = Astro.params.id ?? '';
const env = getRuntimeEnv(Astro.locals);

const row = await getPackById(env.DB, id);
const pack = row ? parsePackRow(row) : null;
const publisher = row ? await getPublisher(env.DB, row.publisher_user_id) : null;
if (!pack) Astro.response.status = 404;

const publisherName = publisher?.name || publisher?.email || (pack ? pack.github_owner : '');
const installHref = pack ? `nevoflux://pack-install?src=${pack.install_src}` : '#';

// The publisher, or any allowlisted admin, may delete a pack.
const currentUser = pack ? await getSessionUser(Astro.locals, Astro.request) : null;
const isOwner = !!(pack && currentUser && currentUser.id === pack.publisher_user_id);
const canDelete = isOwner || (!!currentUser && (await isAdmin(env.DB, currentUser.email)));

const publisherImage = publisher?.image ?? null;
const meta: { label: string; value: string; image?: string | null }[] = pack
  ? [
      { label: ui.detail.version, value: pack.version },
      { label: ui.detail.license, value: pack.license || ui.detail.none },
      { label: ui.detail.downloads, value: String(pack.download_count) },
      { label: ui.detail.publisher, value: publisherName, image: publisherImage },
    ]
  : [];

const displayName = pack ? pack.metadata.displayName || pack.name : '';
const categories = pack?.metadata.categories ?? [];
const topics = pack?.metadata.topics ?? [];
const releaseTags = pack?.metadata.releaseTags ?? [];
const hasChips = categories.length + topics.length + releaseTags.length > 0;

const starCount = pack ? (pack.star_count ?? 0) : 0;
const starred = pack && currentUser ? await hasStarred(env.DB, id, currentUser.id) : false;

const tabs = pack
  ? [
      { key: 'readme', label: ui.detail.readme, value: pack.metadata.readme },
      { key: 'skills', label: ui.detail.skills, value: pack.metadata.skillsText },
      { key: 'seed', label: ui.detail.seed, value: pack.metadata.seedText },
      { key: 'dashboard', label: ui.detail.dashboard, value: pack.metadata.dashboardText },
    ]
  : [];

// Base for resolving relative README image paths to raw.githubusercontent.com.
const rawRef = pack ? pack.github_ref || 'main' : 'main';
const rawImgBase = pack
  ? `https://raw.githubusercontent.com/${pack.github_owner}/${pack.github_repo}/${rawRef}/${pack.github_subdir ? pack.github_subdir + '/' : ''}`
  : '';
---

<Layout
  title={`${pack ? pack.name : ui.detail.notFound} · ${ui.site.title}`}
  description={pack?.description ?? ui.detail.notFound}
>
  <NavBar />
  <main class="container min-h-screen py-32">
    {
      !pack ? (
        <p class="mt-16 text-center text-muted">{ui.detail.notFound}</p>
      ) : (
        <article class="mx-auto max-w-3xl" data-img-base={rawImgBase}>
          <header class="flex flex-wrap items-center gap-3">
            <h1 class="text-3xl font-bold tracking-tight text-dark md:text-4xl">{displayName}</h1>
            {pack.is_official === 1 && (
              <span class="bg-accent/10 rounded-full px-2.5 py-1 text-xs font-medium text-accent">
                {ui.detail.official}
              </span>
            )}
          </header>

          {pack.description && <p class="mt-3 text-lg text-subtle">{pack.description}</p>}

          {hasChips && (
            <div class="mt-4 flex flex-wrap gap-2">
              {categories.map((c) => (
                <span class="border-dark/15 rounded-full border px-2.5 py-0.5 text-xs text-subtle">
                  {c}
                </span>
              ))}
              {topics.map((tp) => (
                <span class="rounded-full bg-surface px-2.5 py-0.5 text-xs text-subtle">#{tp}</span>
              ))}
              {releaseTags.map((rt) => (
                <span class="bg-accent/10 rounded-full px-2.5 py-0.5 text-xs font-medium text-accent">
                  {rt}
                </span>
              ))}
            </div>
          )}

          <div class="mt-6 flex flex-wrap items-center gap-4">
            <a
              id="install-btn"
              href={installHref}
              data-pack-id={pack.id}
              class="rounded-lg bg-accent px-6 py-3 text-sm font-medium text-white transition-colors hover:bg-accent-hover"
            >
              {ui.detail.install}
            </a>
            <button
              id="star-btn"
              data-pack-id={pack.id}
              data-starred={starred ? '1' : '0'}
              data-logged-in={currentUser ? '1' : '0'}
              data-login-url={getPath(locale, '/login')}
              aria-label={ui.detail.stars}
              class:list={[
                'inline-flex items-center gap-1.5 rounded-lg border px-4 py-3 text-sm font-medium transition-colors',
                starred
                  ? 'border-accent/40 text-accent'
                  : 'border-dark/15 text-subtle hover:text-accent',
              ]}
            >
              <span id="star-icon">{starred ? '★' : '☆'}</span>
              <span id="star-count">{starCount}</span>
            </button>
            <a
              href={pack.github_url}
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm font-medium text-subtle transition-colors hover:text-accent"
            >
              {ui.detail.source} ↗
            </a>
            {canDelete && (
              <Fragment>
                <a
                  href={getPath(locale, `/packs/${pack.id}/edit`)}
                  aria-label={ui.detail.edit}
                  title={ui.detail.edit}
                  class="border-dark/15 hover:border-accent/40 ml-auto inline-flex items-center justify-center rounded-lg border p-2 text-subtle transition-colors hover:text-accent"
                >
                  <svg
                    class="h-4 w-4"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d="M12 20h9" />
                    <path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4 12.5-12.5z" />
                  </svg>
                </a>
                <button
                  id="delete-btn"
                  data-pack-id={pack.id}
                  data-confirm={ui.detail.deleteConfirm}
                  data-packs-url={getPath(locale, '/packs')}
                  aria-label={ui.detail.delete}
                  title={ui.detail.delete}
                  class="border-dark/15 inline-flex items-center justify-center rounded-lg border p-2 text-red-600 transition-colors hover:border-red-300 hover:text-red-700"
                >
                  <svg
                    class="h-4 w-4"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <polyline points="3 6 5 6 21 6" />
                    <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2" />
                    <line x1="10" y1="11" x2="10" y2="17" />
                    <line x1="14" y1="11" x2="14" y2="17" />
                  </svg>
                </button>
              </Fragment>
            )}
          </div>

          <dl class="border-dark/10 bg-surface/30 mt-8 grid grid-cols-2 gap-x-6 gap-y-3 rounded-2xl border p-6 text-sm sm:grid-cols-3">
            {meta.map((m) => (
              <div>
                <dt class="text-xs text-muted">{m.label}</dt>
                <dd class="mt-0.5 flex items-center gap-1.5 font-medium text-dark">
                  {m.image && (
                    <img
                      src={m.image}
                      alt=""
                      referrerpolicy="no-referrer"
                      class="border-dark/10 h-5 w-5 rounded-full border object-cover"
                    />
                  )}
                  <span>{m.value}</span>
                </dd>
              </div>
            ))}
          </dl>

          <div class="mt-8">
            <div role="tablist" class="border-dark/10 flex flex-wrap gap-1 border-b">
              {tabs.map((tab, i) => (
                <button
                  type="button"
                  role="tab"
                  data-tab={tab.key}
                  aria-selected={i === 0 ? 'true' : 'false'}
                  class:list={[
                    'pack-tab -mb-px border-b-2 px-4 py-2 text-sm font-medium transition-colors',
                    i === 0
                      ? 'border-accent text-accent'
                      : 'border-transparent text-subtle hover:text-accent',
                  ]}
                >
                  {tab.label}
                </button>
              ))}
            </div>
            {tabs.map((tab, i) => (
              <div class:list={['pack-panel mt-4', { hidden: i !== 0 }]} data-panel={tab.key}>
                {tab.value ? (
                  <div class="prose max-w-none" data-md={tab.value} />
                ) : (
                  <p class="text-sm text-muted">{ui.detail.none}</p>
                )}
              </div>
            ))}
          </div>
        </article>
      )
    }
  </main>
  <Footer />
</Layout>

<script>
  import { marked } from 'marked';
  import DOMPurify from 'dompurify';

  const imgBase = document.querySelector<HTMLElement>('[data-img-base]')?.dataset.imgBase || '';

  // Relative paths and github.com blob/raw image links -> raw CDN.
  const resolveImg = (src: string) => {
    if (!src) return src;
    const blob = src.match(/^https?:\/\/github\.com\/([^/]+)\/([^/]+)\/(?:blob|raw)\/(.+)$/);
    if (blob) return `https://raw.githubusercontent.com/${blob[1]}/${blob[2]}/${blob[3]}`;
    if (/^(?:https?:|data:|\/\/)/i.test(src)) return src; // other absolute URLs: leave as-is
    return imgBase ? imgBase + src.replace(/^\.?\//, '') : src; // relative -> raw base
  };

  // Resolve an in-repo link to a .md file to its raw URL (for in-place loading).
  const resolveMdLink = (href: string): string => {
    if (!href || href.startsWith('#')) return '';
    const clean = href.replace(/[?#].*$/, '');
    const blob = clean.match(/^https?:\/\/github\.com\/([^/]+)\/([^/]+)\/(?:blob|raw)\/(.+\.md)$/i);
    if (blob) return `https://raw.githubusercontent.com/${blob[1]}/${blob[2]}/${blob[3]}`;
    if (/^https?:\/\/raw\.githubusercontent\.com\/.+\.md$/i.test(clean)) return clean;
    if (!/^(?:https?:|data:|\/\/|mailto:)/i.test(clean) && /\.md$/i.test(clean)) {
      return imgBase ? imgBase + clean.replace(/^\.?\//, '') : '';
    }
    return '';
  };

  // Render publisher-supplied markdown safely (sanitized — content is untrusted).
  function renderMd(el: HTMLElement, md: string) {
    el.innerHTML = DOMPurify.sanitize(marked.parse(md, { async: false }) as string);
    el.querySelectorAll('img').forEach((img) => {
      const fixed = resolveImg(img.getAttribute('src') || '');
      if (fixed) img.setAttribute('src', fixed);
    });
    el.querySelectorAll('a').forEach((a) => {
      const mdUrl = resolveMdLink(a.getAttribute('href') || '');
      if (mdUrl) a.dataset.mdUrl = mdUrl;
    });
  }

  document
    .querySelectorAll<HTMLElement>('[data-md]')
    .forEach((el) => renderMd(el, el.dataset.md ?? ''));

  // Clicking an in-repo .md link (e.g. a README language switcher) loads it in place.
  document.querySelector('article')?.addEventListener('click', async (e) => {
    const a = (e.target as HTMLElement).closest?.('a[data-md-url]') as HTMLAnchorElement | null;
    const panel = a?.closest('[data-md]') as HTMLElement | null;
    if (!a || !panel) return;
    e.preventDefault();
    try {
      const res = await fetch(a.dataset.mdUrl as string);
      if (!res.ok) throw new Error(String(res.status));
      renderMd(panel, await res.text());
    } catch {
      window.open(a.dataset.mdUrl, '_blank', 'noopener');
    }
  });

  // Tabs: show one of Readme / Skills / Seed / Dashboard at a time.
  const tabBtns = document.querySelectorAll<HTMLElement>('.pack-tab');
  const panels = document.querySelectorAll<HTMLElement>('.pack-panel');
  tabBtns.forEach((b) =>
    b.addEventListener('click', () => {
      const key = b.dataset.tab;
      tabBtns.forEach((t) => {
        const active = t.dataset.tab === key;
        t.setAttribute('aria-selected', active ? 'true' : 'false');
        t.classList.toggle('border-accent', active);
        t.classList.toggle('text-accent', active);
        t.classList.toggle('border-transparent', !active);
        t.classList.toggle('text-subtle', !active);
      });
      panels.forEach((p) => p.classList.toggle('hidden', p.dataset.panel !== key));
    })
  );

  const btn = document.getElementById('install-btn');
  btn?.addEventListener('click', () => {
    const id = btn.dataset.packId;
    if (id) navigator.sendBeacon(`/api/packs/${id}/install`);
  });

  const star = document.getElementById('star-btn');
  star?.addEventListener('click', async () => {
    if (star.dataset.loggedIn !== '1') {
      window.location.href = star.dataset.loginUrl || '/login';
      return;
    }
    const res = await fetch(`/api/packs/${star.dataset.packId}/star`, { method: 'POST' });
    if (!res.ok) return;
    const data = (await res.json()) as { starred: boolean; starCount: number };
    star.dataset.starred = data.starred ? '1' : '0';
    const icon = document.getElementById('star-icon');
    const count = document.getElementById('star-count');
    if (icon) icon.textContent = data.starred ? '★' : '☆';
    if (count) count.textContent = String(data.starCount);
    star.classList.toggle('text-accent', data.starred);
    star.classList.toggle('border-accent/40', data.starred);
    star.classList.toggle('text-subtle', !data.starred);
    star.classList.toggle('border-dark/15', !data.starred);
  });

  const del = document.getElementById('delete-btn');
  del?.addEventListener('click', async () => {
    const id = del.dataset.packId;
    if (!id || !window.confirm(del.dataset.confirm || 'Delete this pack?')) return;
    const res = await fetch(`/api/packs/${id}/delete`, { method: 'POST' });
    if (res.ok) {
      window.location.href = del.dataset.packsUrl || '/packs';
    } else {
      const data = (await res.json().catch(() => ({}))) as { error?: string };
      window.alert(data.error || `Delete failed (${res.status})`);
    }
  });
</script>
