---
export const prerender = true;

import Layout from '~/layouts/Layout.astro';
import NavBar from '~/components/NavBar.astro';
import Footer from '~/components/Footer.astro';
import { getLocale, getUI, getPath, getStaticPaths as getI18nStaticPaths } from '~/utils/i18n';

export function getStaticPaths() {
  return getI18nStaticPaths();
}

const locale = getLocale(Astro.url);
const ui = getUI(locale);

const inputClass =
  'border-dark/15 focus:border-accent w-full rounded-lg border px-3 py-2 text-sm outline-none';
const labelClass = 'block text-sm font-medium text-dark';
---

<Layout title={`${ui.publish.title} · ${ui.site.title}`} description={ui.publish.subtitle}>
  <NavBar />
  <main class="container min-h-screen py-32">
    <div class="mx-auto max-w-2xl">
      <h1 class="text-3xl font-bold tracking-tight text-dark">{ui.publish.title}</h1>
      <p class="mt-2 text-subtle">{ui.publish.subtitle}</p>

      <form id="source-form" class="mt-8 space-y-3">
        <label for="source" class={labelClass}>{ui.publish.sourceLabel}</label>
        <input
          id="source"
          type="text"
          required
          placeholder={ui.publish.sourcePlaceholder}
          class={inputClass}
        />
        <button
          type="submit"
          class="rounded-lg bg-accent px-5 py-2.5 text-sm font-medium text-white transition-colors hover:bg-accent-hover"
          >{ui.publish.previewBtn}</button
        >
      </form>

      <p id="msg" class="mt-4 text-sm text-subtle"></p>

      <!-- Editor (revealed after a successful preview) -->
      <div id="editor" class="mt-8 hidden">
        <h2 class="text-lg font-bold text-dark">{ui.publish.editTitle}</h2>
        <p id="preview-info" class="mt-1 text-xs text-muted"></p>

        <div class="mt-5 space-y-4">
          <div>
            <label for="f-displayName" class={labelClass}>{ui.publish.displayName}</label>
            <input id="f-displayName" type="text" class={`mt-1 ${inputClass}`} />
          </div>
          <div>
            <label for="f-slug" class={labelClass}>{ui.publish.slug}</label>
            <input id="f-slug" type="text" class={`mt-1 ${inputClass}`} />
          </div>
          <div>
            <label for="f-summary" class={labelClass}>{ui.publish.summary}</label>
            <input id="f-summary" type="text" class={`mt-1 ${inputClass}`} />
          </div>
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label for="f-version" class={labelClass}>{ui.publish.version}</label>
              <input id="f-version" type="text" class={`mt-1 ${inputClass}`} />
            </div>
            <div>
              <label for="f-releaseTags" class={labelClass}>{ui.publish.releaseTags}</label>
              <input id="f-releaseTags" type="text" class={`mt-1 ${inputClass}`} />
            </div>
          </div>
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label for="f-categories" class={labelClass}>{ui.publish.categories}</label>
              <input id="f-categories" type="text" class={`mt-1 ${inputClass}`} />
            </div>
            <div>
              <label for="f-topics" class={labelClass}>{ui.publish.topics}</label>
              <input id="f-topics" type="text" class={`mt-1 ${inputClass}`} />
            </div>
          </div>
          <div>
            <label for="f-readme" class={labelClass}>{ui.publish.readme}</label>
            <textarea id="f-readme" rows="8" class={`mt-1 font-mono ${inputClass}`}></textarea>
          </div>
          <div>
            <label for="f-skills" class={labelClass}>{ui.publish.skills}</label>
            <textarea id="f-skills" rows="4" class={`mt-1 font-mono ${inputClass}`}></textarea>
          </div>
          <div>
            <label for="f-seed" class={labelClass}>{ui.publish.seed}</label>
            <textarea id="f-seed" rows="4" class={`mt-1 font-mono ${inputClass}`}></textarea>
          </div>
          <div>
            <label for="f-dashboard" class={labelClass}>{ui.publish.dashboard}</label>
            <textarea id="f-dashboard" rows="3" class={`mt-1 font-mono ${inputClass}`}></textarea>
          </div>
        </div>

        <button
          id="confirm-btn"
          class="mt-6 rounded-lg bg-accent px-5 py-2.5 text-sm font-medium text-white transition-colors hover:bg-accent-hover"
          >{ui.publish.confirmBtn}</button
        >
      </div>
    </div>
  </main>
  <Footer />
</Layout>

<script
  define:vars={{
    packsUrl: getPath(locale, '/packs'),
    loginUrl: getPath(locale, '/login'),
    t: {
      loading: ui.publish.loading,
      loginRequired: ui.publish.loginRequired,
      success: ui.publish.success,
      official: ui.publish.official,
    },
  }}
>
  const sourceForm = document.getElementById('source-form');
  const sourceInput = document.getElementById('source');
  const msg = document.getElementById('msg');
  const editor = document.getElementById('editor');
  const info = document.getElementById('preview-info');
  const confirmBtn = document.getElementById('confirm-btn');
  let currentSource = '';

  const setVal = (id, v) => {
    const el = document.getElementById(id);
    if (el) el.value = v ?? '';
  };
  const getVal = (id) => document.getElementById(id)?.value ?? '';
  const splitCsv = (s) =>
    s
      .split(',')
      .map((x) => x.trim())
      .filter(Boolean);

  sourceForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (msg) msg.textContent = t.loading;
    editor?.classList.add('hidden');
    currentSource = (sourceInput?.value ?? '').trim();
    const res = await fetch('/api/packs/publish', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ source: currentSource }),
    });
    const data = await res.json();
    if (!res.ok) {
      if (msg) msg.textContent = data.error || 'Error';
      return;
    }
    if (msg) msg.textContent = '';

    const m = data.manifest;
    const c = data.components;
    setVal('f-displayName', m.name);
    setVal('f-slug', m.namespace ? `${m.namespace}/${m.name}` : m.name);
    setVal('f-summary', m.description || '');
    setVal('f-version', m.version);
    setVal('f-releaseTags', '');
    setVal('f-categories', '');
    setVal('f-topics', '');
    setVal('f-readme', data.readme || '');
    setVal('f-skills', (c.skills || []).map((s) => s.name).join('\n'));
    setVal('f-seed', (c.seed || []).join('\n'));
    setVal('f-dashboard', c.dashboard ? 'Yes' : '');

    if (info) {
      const bits = [];
      if (data.isOfficial) bits.push(t.official);
      bits.push('★ ' + data.stars);
      if (data.repoLicense) bits.push(data.repoLicense);
      bits.push(data.installSrc);
      info.textContent = bits.join('  ·  ');
    }
    editor?.classList.remove('hidden');
  });

  confirmBtn?.addEventListener('click', async () => {
    if (msg) msg.textContent = t.loading;
    const edits = {
      displayName: getVal('f-displayName'),
      slug: getVal('f-slug'),
      summary: getVal('f-summary'),
      version: getVal('f-version'),
      releaseTags: splitCsv(getVal('f-releaseTags')),
      categories: splitCsv(getVal('f-categories')),
      topics: splitCsv(getVal('f-topics')),
      readme: getVal('f-readme'),
      skillsText: getVal('f-skills'),
      seedText: getVal('f-seed'),
      dashboardText: getVal('f-dashboard'),
    };
    const res = await fetch('/api/packs/confirm', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ source: currentSource, edits }),
    });
    if (res.status === 401) {
      if (msg) {
        msg.textContent = '';
        const a = document.createElement('a');
        a.href = loginUrl;
        a.className = 'text-accent underline';
        a.textContent = t.loginRequired;
        msg.appendChild(a);
      }
      return;
    }
    const data = await res.json();
    if (!res.ok) {
      if (msg) msg.textContent = data.error || 'Error';
      return;
    }
    if (msg) msg.textContent = t.success;
    window.location.href = packsUrl;
  });
</script>
